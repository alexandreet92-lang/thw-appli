# ══════════════════════════════════════════════
# THW COACHING — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# NE JAMAIS COMMITTER .env.local sur GitHub
# ══════════════════════════════════════════════

# ── Supabase ─────────────────────────────────
# Trouvables dans Supabase Dashboard → Settings → API

# URL de ton projet Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clé anonyme publique (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role (SECRET — server only, jamais dans le browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Strava OAuth ──────────────────────────────
# Trouvables sur https://www.strava.com/settings/api

STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# En développement local
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# En production (remplacer par ton domaine Vercel)
# STRAVA_REDIRECT_URI=https://your-app.vercel.app/api/auth/strava/callback

# ── Anthropic (Claude AI) ─────────────────────
# Pour la page Nutrition — optionnel si tu n'utilises pas l'IA
ANTHROPIC_API_KEY=sk-ant-...

# ── Spoonacular (catalogue de plats) ──────────
# Clé gratuite : https://spoonacular.com/food-api (Profile → API Console)
# Utilisée UNIQUEMENT par `npm run seed:dishes` pour peupler la table
# `dishes` une fois. Pas nécessaire au runtime de l'app.
SPOONACULAR_API_KEY=your_spoonacular_key

# ── Briefing Matinal ──────────────────────────
# UUID du compte Supabase auquel rattacher les briefings générés
# par POST /api/briefing/generate (bypass RLS via service role).
# À récupérer dans Supabase Dashboard → Authentication → Users → ta ligne → User UID
CREATOR_USER_ID=uuid-de-ton-compte-supabase

# Même UUID exposé côté client pour afficher/masquer la section "Actu du jour"
# selon que l'utilisateur connecté est le créateur (un UUID n'est pas un secret).
NEXT_PUBLIC_CREATOR_USER_ID=uuid-de-ton-compte-supabase

# ── Cockpit admin (/admin) ────────────────────
# Email du fondateur autorisé à voir la page de stats /admin.
# SERVER ONLY — ne JAMAIS préfixer NEXT_PUBLIC_ (la garde est côté serveur).
ADMIN_EMAIL=ton-email@exemple.com

# ── Analytics comportemental (temps par page, features) ──
# Collecte DÉSACTIVÉE par défaut. Ne passer à "true" qu'une fois la politique de
# confidentialité + le consentement analytics en ligne. Voir PROMPT_ADMIN_STATS.md §5.
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# ── Notifications push (Web Push / VAPID) ─────────────────
# Génère une paire de clés avec :  npx web-push generate-vapid-keys
# La clé PUBLIQUE est exposée au client (préfixe NEXT_PUBLIC_), la PRIVÉE
# reste server-only. Sans ces variables, le push est un no-op silencieux
# (le reste de l'app fonctionne normalement).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:contact@thw-coaching.app

# ══════════════════════════════════════════════
# NOTES
# ══════════════════════════════════════════════
#
# NEXT_PUBLIC_* → accessible côté client (browser)
# Sans préfixe  → server only (API routes, Server Components)
#
# Sur Vercel : ajouter ces variables dans
# Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════
