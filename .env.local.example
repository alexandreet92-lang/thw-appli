# ══════════════════════════════════════════════
# THW COACHING — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# NE JAMAIS COMMITTER .env.local sur GitHub
# ══════════════════════════════════════════════

# ── Supabase ─────────────────────────────────
# Trouvables dans Supabase Dashboard → Settings → API

# URL de ton projet Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clé anonyme publique (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role (SECRET — server only, jamais dans le browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Strava OAuth ──────────────────────────────
# Trouvables sur https://www.strava.com/settings/api

STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# En développement local
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# En production (remplacer par ton domaine Vercel)
# STRAVA_REDIRECT_URI=https://your-app.vercel.app/api/auth/strava/callback

# ── Anthropic (Claude AI) ─────────────────────
# Pour la page Nutrition — optionnel si tu n'utilises pas l'IA
ANTHROPIC_API_KEY=sk-ant-...

# ══════════════════════════════════════════════
# NOTES
# ══════════════════════════════════════════════
#
# NEXT_PUBLIC_* → accessible côté client (browser)
# Sans préfixe  → server only (API routes, Server Components)
#
# Sur Vercel : ajouter ces variables dans
# Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════
